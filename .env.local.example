# ==============================================================
# ekkoee agent — AI Provider 設定
# ==============================================================
# 三個 provider 共用一套介面(都是 OpenAI-compatible)。
# 只要切換 AI_PROVIDER 的值 + 填對應的 key,立刻換家。
# 本地開發建議 ollama,部署到 Vercel 用 openrouter 或 nvidia。
# ==============================================================

# 選擇啟用的 provider:openrouter | nvidia | ollama
AI_PROVIDER=openrouter


# ==============================================================
# OpenRouter(推薦,免費 tier 選擇多)
# 申請:https://openrouter.ai/  → Dashboard → Keys → Create Key
# 免費 tier 有 rate limit,但首頁 agent 用綽綽有餘
# ==============================================================
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# 其他免費模型(中文強 → 弱排序):
#   deepseek/deepseek-chat-v3:free              ← 中文很強,推薦試
#   qwen/qwen-2.5-72b-instruct:free             ← 阿里,中文原生
#   meta-llama/llama-3.3-70b-instruct:free      ← 通用,英文為主
#   google/gemini-2.0-flash-exp:free            ← 快,中文 ok
#   mistralai/mistral-small-3.1-24b-instruct:free


# ==============================================================
# Nvidia NIM(備援,有免費 credits)
# 申請:https://build.nvidia.com/  → 登入後 API Catalog 取 key
# ==============================================================
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# 其他選項:
#   nvidia/llama-3.1-nemotron-70b-instruct      ← Nvidia 自己調過,回答品質高
#   meta/llama-3.3-70b-instruct
#   mistralai/mixtral-8x22b-instruct-v0.1


# ==============================================================
# Ollama 本地模型(5070Ti 16GB VRAM 測試)
# 安裝:https://ollama.com/download
# 啟動:ollama serve(或裝好後自動跑背景)
# 拉模型:ollama pull qwen2.5:14b
# 列出已裝:ollama list
# ==============================================================
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:14b

# 依你 5070Ti 16GB VRAM 的推薦順序(中文用途):
#   qwen2.5:14b           ← 中文最強,~9GB,推薦首選
#   qwen2.5:7b            ← 速度快,中文也不錯,~5GB
#   llama3.1:8b           ← 英文強,中文普通,~5GB
#   gemma2:9b             ← Google 出品,中文 ok,~6GB
#   qwen2.5:32b-instruct-q4_K_M  ← 極限挑戰,~20GB 會 offload 到 CPU,會慢
